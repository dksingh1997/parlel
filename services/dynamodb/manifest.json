{
  "name": "dynamodb",
  "version": "0.1",
  "image": "parlel/dynamodb:0.1",
  "size_kb": 64,
  "port": 4567,
  "protocol": "http",
  "healthcheck": "/_parlel/health",
  "startup_time_ms": 100,
  "env_vars": {
    "AWS_ACCESS_KEY_ID": "parlel",
    "AWS_SECRET_ACCESS_KEY": "parlel",
    "AWS_REGION": "us-east-1",
    "AWS_ENDPOINT_URL_DYNAMODB": "http://127.0.0.1:4567"
  }
}

{
  "name": "eventbridge",
  "version": "0.1",
  "image": "parlel/eventbridge:0.1",
  "size_kb": 90,
  "port": 4573,
  "protocol": "http",
  "category": "messaging",
  "healthcheck": "/_parlel/health",
  "startup_time_ms": 100,
  "env_vars": {
    "AWS_ACCESS_KEY_ID": "parlel",

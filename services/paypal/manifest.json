{
  "name": "paypal",
  "version": "1.0",
  "image": "parlel/paypal:1.0",
  "size_kb": 64,
  "port": 4760,
  "protocol": "http",
  "healthcheck": "/health",
  "startup_time_ms": 100,
  "env_vars": {
    "PAYPAL_CLIENT_ID": "parlel-client-id",
    "PAYPAL_CLIENT_SECRET": "parlel-client-secret",
    "PAYPAL_BASE_URL": "http://127.0.0.1:4760"
  }
}
